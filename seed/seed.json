{
	"$schema": "https://emdashcms.com/seed.schema.json",
	"version": "1",
	"meta": {
		"name": "Reality Tokens CMS",
		"description": "Collection Management System for Reality Tokens - CAT-721 NFTs with spatial grounding",
		"author": "CurrentSeas"
	},

	"settings": {
		"title": "Reality Tokens CMS",
		"tagline": "Managing Digital Twins with Covenants of Ownership"
	},

	"collections": [
		{
			"slug": "opcat_collections",
			"label": "Art Collections",
			"labelSingular": "Collection",
			"supports": ["drafts", "revisions", "search"],
			"fields": [
				{
					"slug": "name",
					"label": "Collection Name",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "slug",
					"label": "URL Slug",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "subtitle",
					"label": "Subtitle",
					"type": "string"
				},
				{
					"slug": "description",
					"label": "Description",
					"type": "portableText",
					"searchable": true
				},
				{
					"slug": "theme_gradient",
					"label": "Theme Gradient (CSS)",
					"type": "string",
					"help": "e.g., linear-gradient(135deg, #001a33 0%, #003366 50%, #004080 100%)"
				},
				{
					"slug": "featured_model",
					"label": "Featured 3D Model (GLB URL)",
					"type": "file",
					"help": "Path to the main 3D model for this collection"
				},
				{
					"slug": "opcat_contract",
					"label": "CAT-721 Contract Address",
					"type": "string",
					"help": "On-chain contract address for this collection"
				},
				{
					"slug": "minter_type",
					"label": "Minter Type",
					"type": "select",
					"options": ["open", "closed"],
					"help": "Open = anyone can mint, Closed = only issuer can mint"
				},
				{
					"slug": "covenant_preview",
					"label": "Covenant Preview (JSON)",
					"type": "json",
					"help": "Preview of attestation data for CAT-721"
				},
				{
					"slug": "status",
					"label": "Status",
					"type": "select",
					"options": ["draft", "live", "archived"]
				}
			]
		},
		{
			"slug": "opcat_artworks",
			"label": "Artworks",
			"labelSingular": "Artwork",
			"supports": ["drafts", "revisions", "search", "seo"],
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "slug",
					"label": "URL Slug",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "collection",
					"label": "Collection",
					"type": "relation",
					"collection": "opcat_collections",
					"required": true
				},
				{
					"slug": "featured_image",
					"label": "Featured Image",
					"type": "image"
				},
				{
					"slug": "model_3d",
					"label": "3D Model (GLB URL)",
					"type": "file",
					"help": "Individual 3D model for this artwork"
				},
				{
					"slug": "splat_url",
					"label": "Gaussian Splat URL",
					"type": "url",
					"help": "URL to Gaussian splat for photorealistic XR"
				},
				{
					"slug": "description",
					"label": "Description",
					"type": "portableText",
					"searchable": true
				},
				{
					"slug": "cat721_token_id",
					"label": "CAT-721 Token ID",
					"type": "string",
					"help": "The token ID on-chain"
				},
				{
					"slug": "cat721_txid",
					"label": "Mint Transaction ID",
					"type": "string",
					"help": "Bitcoin transaction ID where this was minted"
				},
				{
					"slug": "covenant_hash",
					"label": "Covenant Hash",
					"type": "string",
					"help": "Hash of the covenant attestation"
				},
				{
					"slug": "geo_location",
					"label": "Geo Location (JSON)",
					"type": "json",
					"help": "{ lat: number, lng: number, radius: number } for spatial tethering"
				},
				{
					"slug": "xr_settings",
					"label": "XR Settings (JSON)",
					"type": "json",
					"help": "AR/VR config: { scale, orientation, ar_placement, etc. }"
				},
				{
					"slug": "fractional_holders",
					"label": "Fractional Holders (JSON)",
					"type": "json",
					"help": "Array of holder addresses and their shares"
				},
				{
					"slug": "attributes",
					"label": "Attributes (JSON array)",
					"type": "json",
					"help": "Standard NFT attributes: [{ trait_type, value }]"
				},
				{
					"slug": "content_type",
					"label": "Content Type (MIME)",
					"type": "string",
					"help": "e.g., image/jpeg, model/gltf-binary"
				},
				{
					"slug": "content_body",
					"label": "Content Body (URI or data)",
					"type": "text",
					"help": "URI to content or inline data for CAT-721"
				},
				{
					"slug": "status",
					"label": "Status",
					"type": "select",
					"options": ["draft", "live", "minted"]
				}
			]
		}
	],

	"taxonomies": [
		{
			"name": "category",
			"label": "Categories",
			"labelSingular": "Category",
			"hierarchical": true,
			"collections": ["opcat_artworks"],
			"terms": [
				{ "slug": "digital-art", "label": "Digital Art" },
				{ "slug": "3d-model", "label": "3D Model" },
				{ "slug": "xr-experience", "label": "XR Experience" },
				{ "slug": "spatial-art", "label": "Spatial Art" }
			]
		},
		{
			"name": "tag",
			"label": "Tags",
			"labelSingular": "Tag",
			"hierarchical": false,
			"collections": ["opcat_artworks"],
			"terms": [
				{ "slug": "sea-sirens", "label": "Sea Sirens" },
				{ "slug": "ocean", "label": "Ocean" },
				{ "slug": "abstract", "label": "Abstract" },
				{ "slug": "ar-ready", "label": "AR Ready" },
				{ "slug": "fractional", "label": "Fractional" }
			]
		}
	],

	"bylines": [
		{
			"id": "byline-currentseas",
			"slug": "currentseas-studio",
			"displayName": "CurrentSeas Studio"
		},
		{
			"id": "byline-seasirens",
			"slug": "sea-sirens-design",
			"displayName": "Sea Sirens Design"
		}
	],

	"menus": [
		{
			"name": "primary",
			"label": "Primary Navigation",
			"items": [
				{ "type": "custom", "label": "Home", "url": "/" },
				{ "type": "custom", "label": "Collections", "url": "/collections" },
				{ "type": "custom", "label": "Gallery", "url": "/gallery" }
			]
		}
	],

